# RETRO Pipeline — Environment Variables
# Copy ke .env dan isi nilai yang diperlukan:
#   cp .env.example .env

# ===== WAJIB =====
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== LLM Config =====
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# ===== Proposal Config =====
PROPOSAL_AUTHOR=Yoel
PROPOSAL_THEME=light

# ===== Pipeline Config =====
INPUT_FILE=sample_companies.csv
OUTPUT_DIR=./output
DB_PATH=./retro.db

# ===== Optional: Email Discovery =====
HUNTER_API_KEY=
APOLLO_API_KEY=
SNOV_API_KEY=

# ===== Optional: Email Sending =====
RESEND_API_KEY=
SENDER_EMAIL=retro@yourdomain.com
SENDER_NAME=RETRO Business Intelligence

# ===== Optional: Notification =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Optional: OSINT =====
SHODAN_API_KEY=
CRUNCHBASE_API_KEY=

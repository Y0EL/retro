# RETRO Pipeline — Environment Variables
# Copy ke .env dan isi nilai yang diperlukan:
#   cp .env.example .env

# ===== WAJIB =====
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== LLM Config =====
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# ===== Proposal Config =====
PROPOSAL_AUTHOR=PT GSP
PROPOSAL_THEME=light

# ===== Pipeline Config =====
INPUT_FILE=sample_companies.csv
OUTPUT_DIR=./output
DB_PATH=./retro.db
PROFILE_CONTEXT_MAX_CHARS=8000

# ===== Storage =====
POSTGRES_URL=postgresql://retro:retro@localhost:5432/retro
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# ===== Optional: Email Discovery =====
HUNTER_API_KEY=
APOLLO_API_KEY=
SNOV_API_KEY=

# ===== Optional: Email Sending =====
RESEND_API_KEY=
SENDER_EMAIL=retro@yourdomain.com
SENDER_NAME=RETRO Business Intelligence

# ===== Optional: Notification =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Optional: OSINT =====
SHODAN_API_KEY=
CRUNCHBASE_API_KEY=

# ===== Microservice URLs (dipakai TypeScript backend) =====
CRAWLER_SERVICE_URL=http://localhost:8001
EXTRACTION_SERVICE_URL=http://localhost:8002
LLM_SERVICE_URL=http://localhost:8003
OSINT_SERVICE_URL=http://localhost:8004
PDF_SERVICE_URL=http://localhost:8005
STORAGE_SERVICE_URL=http://localhost:8006

# ===== Backend / Frontend =====
BACKEND_PORT=3001
FRONTEND_PORT=3000
